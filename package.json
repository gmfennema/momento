{
  "name": "momento",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Audio on a business card — encode ≤10s of audio into laser-engravable QR codes, decode by scanning the card. No server, no storage.",
  "license": "MIT",
  "scripts": {
    "postinstall": "node scripts/copy-zxing.mjs",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "zxing-wasm": "^3.1.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/qrcode": "^1.5.5",
    "pngjs": "^7.0.0",
    "@types/pngjs": "^6.0.5",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^3.0.0"
  }
}
